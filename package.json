{
  "name": "picotester",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "homepage": "https://ahuertam.github.io/picoTester",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .js,.jsx",
    "format": "prettier --write \"src/**/*.{js,jsx,css,md}\"",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "gh-pages": "^6.1.1",
    "postcss": "^8.4.47",
    "prettier": "^3.3.2",
    "prettier-plugin-tailwindcss": "^0.6.6",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
